{
  "schemaVersion": 1,
  "activation": {
    "triggers": ["ship", "ship please", "shipping", "tctbp", "prepare release", "deploy", "deploy please", "handover", "handover please"],
    "caseInsensitive": true,
    "branchCommand": {
      "enabled": true,
      "pattern": "^branch\\s+(.+)$"
    }
  },
  "projectProfile": {
    "lint": "cargo clippy -- -D warnings",
    "format": "cargo fmt -- --check",
    "test": "cargo test",
    "build": "cargo build",
    "releaseBuild": "cargo build --release",
    "releaseBuildPolicy": "explicit-installation-or-deployment-only",
    "versionFile": "Cargo.toml",
    "versionField": "package.version"
  },
  "workflow": {
    "order": ["preflight", "test", "problems", "docsImpact", "bump", "commit", "tag", "push"],
    "requireApproval": ["push"]
  },
  "handover": {
    "preferredTriggers": ["handover", "handover please"],
    "primaryObjective": "No code is ever lost while syncing local and remote state.",
    "purpose": "Reconcile local and remote branch state so any machine can continue from the latest validated shared work.",
    "preserveUncommittedChanges": true,
    "requireDurableCheckpointBeforeReconciliation": true,
    "allowFastForwardOnlyWhenClean": true,
    "pushCurrentBranch": true,
    "createUpstreamIfMissing": true,
    "stopOnDivergence": true,
    "stopOnAmbiguity": true,
    "allowAutoRebase": false,
    "allowHardReset": false,
    "allowDestructiveCheckout": false,
    "allowForcePush": false,
    "pushTagsWhenPresent": true
  },
  "deploy": {
    "preferredTriggers": ["deploy", "deploy please"],
    "purpose": "Build a runtime-ready artefact and update it safely in the configured target environment.",
    "requireCleanTree": true,
    "requireSyncedBranch": true,
    "requireShipFirst": false,
    "buildCommand": "cargo build --release",
    "migrationCommand": null,
    "targets": {
      "linux-user-local": {
        "description": "Install the release binary and desktop entry into the current user's local application paths.",
        "installCommands": [
          "install -Dm755 target/release/rust-clock ~/.local/bin/rust-clock",
          "install -Dm644 assets/rust-clock.desktop ~/.local/share/applications/rust-clock.desktop"
        ],
        "postDeployChecks": [
          "test -x ~/.local/bin/rust-clock",
          "test -f ~/.local/share/applications/rust-clock.desktop"
        ]
      },
      "windows-installer": {
        "description": "Build the Windows installer package for deployment or distribution.",
        "installCommands": [
          "pwsh -File .\\installer\\windows\\build-installer.ps1"
        ],
        "postDeployChecks": [
          "test -d dist/windows"
        ]
      }
    }
  },
  "documentation": {
    "requireImpactAssessment": true,
    "blockShipIfUnassessed": true,
    "allowNoDocChangeWithReason": true,
    "changeTypes": [
      "user-visible-feature",
      "ui-or-interaction",
      "config-or-settings",
      "packaging-or-metadata",
      "roadmap-or-status",
      "internal-only"
    ],
    "rules": [
      {
        "changeType": "user-visible-feature",
        "review": ["README.md", "docs/user-guide.md", "PLAN.md"]
      },
      {
        "changeType": "ui-or-interaction",
        "review": ["README.md", "docs/user-guide.md"]
      },
      {
        "changeType": "config-or-settings",
        "review": ["README.md", "docs/user-guide.md"]
      },
      {
        "changeType": "packaging-or-metadata",
        "review": ["README.md", "Cargo.toml", "assets/rust-clock.desktop"]
      },
      {
        "changeType": "roadmap-or-status",
        "review": ["PLAN.md"]
      },
      {
        "changeType": "internal-only",
        "review": []
      }
    ]
  },
  "versioning": {
    "scheme": "semver",
    "patchEveryShip": true,
    "skipForChangeTypes": ["docs-only", "infrastructure-only"],
    "minorOnFirstShipOfBranch": true,
    "majorExplicitOnly": true
  },
  "tagging": {
    "policy": "everyCommit",
    "skipWhenNoBump": true,
    "format": "{version}"
  }
}
